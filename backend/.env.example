# ─────────────────────────────────────────────────────────────
# Configuración del servidor
# ─────────────────────────────────────────────────────────────

# Puerto en el que escucha el servidor (Railway/Render lo inyectan automáticamente)
PORT=3000

# Entorno de ejecución: development | production
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# Base de datos PostgreSQL
# ─────────────────────────────────────────────────────────────

# URL de conexión completa (recomendado para producción en Railway/Render/Neon)
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/todosdb

# ─────────────────────────────────────────────────────────────
# Alternativa: variables individuales (si no usas DATABASE_URL)
# ─────────────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=todosdb
